{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the Card Crush main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$HOME/**" }, { "path": "$DESKTOP/**" }, { "path": "$DOCUMENT/**" }, { "path": "$DOWNLOAD/**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$HOME/**" }, { "path": "$DESKTOP/**" }, { "path": "$DOCUMENT/**" }, { "path": "$DOWNLOAD/**" }]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.scryfall.com/*" },
        { "url": "https://*.scryfall.io/*" },
        { "url": "https://*.scryfall.com/*" },
        { "url": "https://api.lorcast.com/*" },
        { "url": "https://*.lorcast.com/*" },
        { "url": "https://api.pokemontcg.io/*" },
        { "url": "https://*.pokemontcg.io/*" },
        { "url": "https://api.swu-db.com/*" },
        { "url": "https://*.swu-db.com/*" },
        { "url": "https://api.swuapi.com/*" },
        { "url": "https://*.swuapi.com/*" },
        { "url": "https://optcgapi.com/*" },
        { "url": "https://*.optcgapi.com/*" }
      ]
    }
  ]
}
